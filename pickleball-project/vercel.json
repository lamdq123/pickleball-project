{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/",
            "destination": "/frontend/dist/index.html"
        },
        {
            "source": "/login",
            "destination": "/frontend/dist/index.html"
        },
        {
            "source": "/admin",
            "destination": "/frontend/dist/index.html"
        },
        {
            "source": "/(.*)",
            "destination": "/frontend/dist/$1"
        }
    ]
}